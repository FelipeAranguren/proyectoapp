{
  "kind": "collectionType",
  "collectionName": "pedidos",
  "info": {
    "singularName": "pedido",
    "pluralName": "pedidos",
    "displayName": "Pedido"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "numero_mesa": {
      "type": "string"
    },
    "estado": {
      "type": "enumeration",
      "enum": [
        "Pendiente",
        "En preparación",
        "Listo",
        "Entregado",
        "Cancelado"
      ]
    },
    "total": {
      "type": "decimal"
    },
    "fecha_hora": {
      "type": "datetime"
    },
    "restaurante": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::restaurante.restaurante"
    },
    "items": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::item-pedido.item-pedido"
    }
  }
}
